NODE_ENV=development
# Cadena de conexión directa a Supabase para Prisma (pooling desactivado, requerida para migraciones)
# Usa el puerto 5432 para conexión directa (no el pooler 6543)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# QStash configuration from Upstash console
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
# Public app URL for QStash callbacks
NEXT_PUBLIC_APP_URL=https://localhost:3000